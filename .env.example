# Required: Discord bot token from the Discord Developer Portal.
DISCORD_TOKEN=

# Optional but recommended for first setup.
# Set to your Discord server ID so slash commands sync instantly while testing.
GUILD_DISCORD_ID=

# Public defaults used before database setup commands are run.
# HOME_GUILD_NAME should match the Albion Online guild name.
HOME_GUILD_NAME=HomeGuild
HOME_GUILD_ROLE_NAME=HomeGuild
HOME_GUILD_NICK_TAG=HG
HOME_ALLIANCE_TAG=ALLY

# Optional AI helper.
# Leave OPENAI_API_KEY blank to keep OpenAI disabled.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional local AI fallback.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Optional: set to DEBUG while developing.
LOG_LEVEL=INFO

# Optional: comma-separated cog names to skip at startup.
# Example: ai_assistant,openai_moderation,message_memory
DISABLED_COGS=
